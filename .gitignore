# ==========================================
# FILE DATA & MODEL (Paling Penting!)
# ==========================================
# Jangan upload data mentah atau data hasil olahan ke Git
*.csv
*.xlsx
*.json
*.parquet
*.feather
*.pkl
*.pickle
*.h5
*.hd5
*.npy
*.npz

# Jika Anda membuat folder khusus data dan model, abaikan seluruh isinya
data/
models/
output/
artifacts/

# Kecuali Anda ingin menyertakan folder kosongnya saja, gunakan rules ini:
!data/
!data/.gitkeep
!models/
!models/.gitkeep

# Pengecualian khusus untuk file data & model dashboard agar dapat di-upload ke GitHub:
!processed_data/features/features_all_dataset.csv
!processed_data/merged/dataset_all_merged.csv
!models/model_rf.pkl
!models/feature_columns.json
!models/training_metadata.json
!results/evaluation_per_commodity.csv


# ==========================================
# ENVIRONMENTS & DEPENDENCIES
# ==========================================
