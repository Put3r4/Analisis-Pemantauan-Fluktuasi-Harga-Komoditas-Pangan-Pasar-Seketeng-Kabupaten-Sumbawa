.venv/
venv/
env/
ENV/
bin/
lib/
share/
pyvenv.cfg
.CondaSettings/

# ==========================================
# JUPYTER NOTEBOOK CACHE & CHECKPOINTS
# ==========================================
.ipynb_checkpoints
*/.ipynb_checkpoints/*
__pycache__/
*.py[cod]
*$py.class

# ==========================================
# KONFIGURASI DAN SKRIP RAHASIA (SECURITY)
